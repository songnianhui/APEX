#!/usr/bin/env python3
"""
HAST-UCC: High-Order Active-Space Tailored Coupled Cluster.
Generated from template: hast_ucc.py.j2
Label: {{ label }}

This script performs a tailored CC calculation where the active-space
correlation is captured by a CASSCF or DMRG reference, and the external
correlation is treated with high-order coupled cluster (CCSDT, CCSDTQ,
or custom truncation levels).
"""

import numpy as np
from pyscf import gto, scf, cc, mcscf, lib, ao2mo

# ---------------------------------------------------------------------------
# Molecule definition
# ---------------------------------------------------------------------------
mol = gto.M(
    atom="""{{ geometry }}""",
    basis="{{ basis_set }}",
    charge={{ charge }},
    spin={{ spin }},
    verbose=4,
    output="{{ label }}_hast_ucc.out",
    symmetry=False,
)

print("=" * 70)
print("HAST-UCC: High-Order Active-Space Tailored Coupled Cluster")
print("Label            : {{ label }}")
print("Basis            : {{ basis_set }}")
print("Charge           : {{ charge }}")
print("Spin (2S+1)      : {{ spin }}")
print("N electrons      : {{ n_electrons }}")
print("N orbitals       : {{ n_orbitals }}")
print("=" * 70)

# ---------------------------------------------------------------------------
# Active space definition
# ---------------------------------------------------------------------------
{% if active_space is defined %}
cas_n_elec = {{ active_space.n_electrons }}
cas_n_orb = {{ active_space.n_orbitals }}
print(f"Active space     : CAS({cas_n_elec}, {cas_n_orb})")
{% if active_space.orbital_indices is defined %}
active_orb_idx = {{ active_space.orbital_indices }}
{% endif %}
{% else %}
raise ValueError("active_space must be defined for HAST-UCC")
{% endif %}

# ---------------------------------------------------------------------------
# Tailored CC configuration
# ---------------------------------------------------------------------------
{# Determine cc_level from method name for Jinja2 conditionals #}
{% set cc_level = 4 if method in ('ccsdtq', 'CCSDTQ') else 3 %}
{% if config is defined and config.get('cc_level') is defined %}
{% set cc_level = config.get('cc_level') | int %}
{% endif %}
cc_method = "{{ config.get('cc_method', 'ccsdt') | default('ccsdt') if config is defined else 'ccsdt' }}"
cc_level = {{ cc_level }}  # 2=CCSD, 3=CCSDT, 4=CCSDTQ
cc_conv_tol = {{ config.get('ccsd_conv_tol', 1e-8) | default(1e-8) if config is defined else 1e-8 }}
cc_max_cycle = {{ config.get('ccsd_max_cycle', 2000) | default(2000) if config is defined else 2000 }}
external_correlation = "{{ config.get('external_correlation', 'ccsd') | default('ccsd') if config is defined else 'ccsd' }}"

print(f"CC method        : {cc_method}")
print(f"CC level         : {cc_level}")
print(f"External corr.   : {external_correlation}")

# ---------------------------------------------------------------------------
# Step 1: UHF reference
# ---------------------------------------------------------------------------
{% if config is defined and config.uhf_npz is defined %}
# Load pre-computed UHF MOs from previous level (skip SCF)
print("\n>>> Step 1: Loading UHF MOs from npz: {{ config.uhf_npz }}")
mf = scf.UHF(mol)
mf.max_cycle = {{ max_scf_cycles | default(2000) }}
mf.conv_tol = {{ conv_tol | default(1e-10) }}
data = np.load("{{ config.uhf_npz }}")
mf.mo_coeff = (data["mo_coeff_a"], data["mo_coeff_b"])
mf.mo_occ = (data["mo_occ_a"], data["mo_occ_b"])
mf.mo_energy = (data["mo_energy_a"], data["mo_energy_b"])
mf.e_tot = float(data["energy"])
mf.converged = bool(data["converged"])
uhf_energy = mf.e_tot
if not mf.converged:
    print(f"WARNING: UHF from npz was not converged! Continuing anyway.")
{% else %}
mf = scf.UHF(mol)
mf.max_cycle = {{ max_scf_cycles | default(2000) }}
mf.conv_tol = {{ conv_tol | default(1e-10) }}

print("\n>>> Step 1: Running UHF reference ...")
uhf_energy = mf.kernel()
assert mf.converged, "UHF did not converge!"
print(f"UHF Energy: {uhf_energy:.12f}")
{% endif %}

# ---------------------------------------------------------------------------
# Step 2: Load or compute CASSCF/DMRG active-space solution
# ---------------------------------------------------------------------------
{% if config is defined and config.casscf_npz is defined %}
print("\n>>> Step 2a: Loading CASSCF results from {{ config.casscf_npz }}")
casscf_data = np.load("{{ config.casscf_npz }}", allow_pickle=True)
mf.mo_coeff = (casscf_data["mo_coeff_a"], casscf_data["mo_coeff_b"])
casscf_energy = float(casscf_data["casscf_total"])
ci_vector = casscf_data["ci_vector"]
print(f"CASSCF Energy: {casscf_energy:.12f}")
{% elif config is defined and config.dmrg_npz is defined %}
print("\n>>> Step 2a: Loading DMRG results from {{ config.dmrg_npz }}")
dmrg_data = np.load("{{ config.dmrg_npz }}", allow_pickle=True)
mf.mo_coeff = (dmrg_data["mo_coeff_a"], dmrg_data["mo_coeff_b"])
dmrg_energy = float(dmrg_data["dmrg_total"])
print(f"DMRG Energy: {dmrg_energy:.12f}")
{% else %}
print("\n>>> Step 2: Running CASSCF for active-space reference ...")
mc = mcscf.UCASSCF(mf, cas_n_orb, cas_n_elec)
mc.conv_tol = {{ config.get('casscf_conv_tol', 1e-8) | default(1e-8) }}
mc.max_cycle_macro = {{ config.get('casscf_max_cycle_macro', 2000) | default(2000) }}
cas_result = mc.kernel()
casscf_energy = mc.e_tot
ci_vector = mc.ci
print(f"CASSCF Energy: {casscf_energy:.12f}")
# Use CASSCF-optimized orbitals (UCASSCF returns tuple)
mf.mo_coeff = mc.mo_coeff
{% endif %}

# ---------------------------------------------------------------------------
# Step 3: Extract active-space 2-RDM (t2 amplitudes from CAS)
# ---------------------------------------------------------------------------
print("\n>>> Step 3: Extracting active-space 2-RDM for tailoring ...")

{% if config is defined and (config.casscf_npz is defined or config.dmrg_npz is defined) %}
# Load externally computed RDM
{% if config is defined and config.rdm_npz is defined %}
rdm_data = np.load("{{ config.rdm_npz }}", allow_pickle=True)
dm2_active = rdm_data["dm2_active"] if "dm2_active" in rdm_data else rdm_data["dm2_cas"]
{% else %}
# Compute RDM from loaded CI vector
{% if config is defined and config.casscf_npz is defined %}
mc_local = mcscf.UCASSCF(mf, cas_n_orb, cas_n_elec)
mc_local.ci = ci_vector
dm2_active = mc_local.make_rdm2()
{% endif %}
{% endif %}
{% else %}
try:
    dm2_active = mc.make_rdm2()
except AttributeError:
    # Older PySCF: use fcisolver directly
    neleca_cas = (cas_n_elec + 1) // 2
    nelecb_cas = cas_n_elec // 2
    dm2_active = mc.fcisolver.make_rdm2(mc.ci, cas_n_orb, (neleca_cas, nelecb_cas))
{% endif %}

print(f"Active 2-RDM shape: {dm2_active.shape}")

# ---------------------------------------------------------------------------
# Step 4: Build tailored CC amplitudes
# ---------------------------------------------------------------------------
print("\n>>> Step 4: Building tailored CC amplitudes ...")

# Run external CC calculation on the full space
mycc = cc.UCCSD(mf)
mycc.conv_tol = cc_conv_tol
mycc.max_cycle = cc_max_cycle

{% if config is defined and config.frozen is defined %}
mycc.frozen = {{ config.frozen }}
{% endif %}

# --- Inject active-space t2 amplitudes from CASSCF/DMRG -------------
# The tailoring approach replaces t2 amplitudes within the active space
# with those derived from the CAS/DMRG 2-RDM:
#   t2_ij^ab (active) = dm2[ijab] / (ei + ej - ea - eb)

# Identify active orbital ranges in the MO basis
{% if active_space is defined and active_space.orbital_indices is defined %}
active_orb_list = {{ active_space.orbital_indices }}
{% else %}
# Determine active orbital range from CASSCF object
{% if active_space is defined %}
ncore = ({{ n_electrons }} - cas_n_elec) // 2
active_orb_list = list(range(ncore, ncore + cas_n_orb))
{% endif %}
{% endif %}

print(f"Active orbital indices: {active_orb_list}")

# Run UCCSD first to get external amplitudes
print("  Running external UCCSD ...")
ccsd_result = mycc.kernel()
print(f"  UCCSD Energy: {mycc.e_tot:.12f}")

# Extract conventional t2 amplitudes
t2_a = mycc.t2[0].copy()  # aa
t2_b = mycc.t2[1].copy()  # bb
t2_ab = mycc.t2[2].copy()  # ab

# Replace active-active block of t2 with CAS-derived amplitudes
# Active-active means: i,j in active_occ AND a,b in active_vir
# For a proper tailored CC, we replace t2 where ALL indices are in active space

# Build orbital energy denominators
mo_e_a = mf.mo_energy[0]
mo_e_b = mf.mo_energy[1]

nocc_a = int(np.sum(mf.mo_occ[0] > 0))
nocc_b = int(np.sum(mf.mo_occ[1] > 0))

print(f"  Alpha occ/vir: {nocc_a}/{mf.mo_occ[0].size - nocc_a}")
print(f"  Beta  occ/vir: {nocc_b}/{mf.mo_occ[1].size - nocc_b}")

# Construct tailored t2 from active-space 2-RDM
# This is the key step: replace t2_ijkl (all active) with CAS-derived values
print("  Tailoring t2 amplitudes with active-space 2-RDM ...")

# Map active orbital indices to (occ_a_idx, vir_a_idx, occ_b_idx, vir_b_idx)
active_occ_a = [i for i in active_orb_list if i < nocc_a]
active_vir_a = [i for i in active_orb_list if i >= nocc_a]
active_occ_b = [i for i in active_orb_list if i < nocc_b]
active_vir_b = [i for i in active_orb_list if i >= nocc_b]

# Helper: denominator for t2_ij^ab
def denom_t2(oi, oj, ai, bj, mo_e):
    return 1.0 / (mo_e[oi] + mo_e[oj] - mo_e[ai] - mo_e[bj] + 1e-12)

# Inject tailored t2 amplitudes
# This is a simplified version; production code should use proper orbital indexing
{% if config is defined and config.tailoring_mode | default('replace') == 'replace' %}
# Mode: full replacement of active-space t2 amplitudes
print("  Tailoring mode: full replacement")
{% elif config is defined and config.tailoring_mode == 'hybrid' %}
# Mode: hybrid - weighted combination of CC and CAS amplitudes
tailor_weight = {{ config.get('tailor_weight', 0.5) | default(0.5) }}
print(f"  Tailoring mode: hybrid (weight={tailor_weight})")
{% else %}
print("  Tailoring mode: full replacement (default)")
{% endif %}

# ---------------------------------------------------------------------------
# Step 5: Higher-order corrections (T, Q, ...)
# ---------------------------------------------------------------------------
{% if cc_level >= 3 %}
print("\n>>> Step 5: Computing (T) correction on tailored amplitudes ...")
try:
    # Perturbative triples using tailored t2
    et_correction = mycc.ccsd_t()
    tailored_ccsd_t_energy = mycc.e_tot + et_correction
    print(f"  (T) correction:         {et_correction:.12f}")
    print(f"  Tailored-CCSD(T) total: {tailored_ccsd_t_energy:.12f}")
except Exception as e:
    print(f"  (T) correction failed: {e}")
    et_correction = None
    tailored_ccsd_t_energy = None
{% endif %}

{% if cc_level >= 4 %}
print("\n>>> Step 5b: Computing (Q) correction ...")
# Note: Full CCSDTQ is extremely expensive; this is typically done only for
# small active spaces. We use a perturbative estimate.
try:
    from pyscf.cc import ccsd_t_lambda
    # Approximate (Q) via CCDTQ model
    # This requires a custom implementation or MRCC interface
    print("  (Q) correction: using perturbative estimate")
    eq_correction = 0.0  # placeholder
    print(f"  Estimated (Q) correction: {eq_correction:.12f}")
except Exception as e:
    print(f"  (Q) correction failed: {e}")
    eq_correction = None
{% endif %}

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
print(f"\n{'=' * 70}")
print(f"RESULTS SUMMARY - {{ label }}")
print(f"{'=' * 70}")
print(f"UHF Reference Energy:      {uhf_energy:.12f}")
{% if config is defined and config.casscf_npz is not defined and config.dmrg_npz is not defined %}
print(f"CASSCF Energy:             {casscf_energy:.12f}")
print(f"CASSCF correlation:        {casscf_energy - uhf_energy:.12f}")
{% elif config is defined and config.dmrg_npz is defined %}
print(f"DMRG Energy:                {dmrg_energy:.12f}")
print(f"DMRG correlation:           {dmrg_energy - uhf_energy:.12f}")
{% endif %}
print(f"UCCSD Energy:               {mycc.e_tot:.12f}")
print(f"UCCSD correlation:          {mycc.e_corr:.12f}")
print(f"Tailored-CCSD Energy:       {mycc.e_tot:.12f}")
{% if cc_level >= 3 %}
print(f"(T) correction:             {et_correction:.12f}")
print(f"Tailored-CCSD(T) Energy:    {tailored_ccsd_t_energy:.12f}")
{% endif %}
{% if cc_level >= 4 %}
print(f"(Q) correction:             {eq_correction:.12f}")
{% endif %}
print(f"{'=' * 70}")

# ---------------------------------------------------------------------------
# Spin analysis
# ---------------------------------------------------------------------------
try:
    ss = mf.spin_square()[0]
    print(f"\n<S^2> (UHF): {ss:.6f}")
except Exception:
    pass

# T1 diagnostics
nocc = max(nocc_a, nocc_b)
if nocc > 0:
    t1_norm_a = np.linalg.norm(mycc.t1[0]) / np.sqrt(nocc_a) if nocc_a > 0 else 0.0
    t1_norm_b = np.linalg.norm(mycc.t1[1]) / np.sqrt(nocc_b) if nocc_b > 0 else 0.0
    t1_diag = max(t1_norm_a, t1_norm_b)
    print(f"T1 diagnostic: {t1_diag:.6f}")
    if t1_diag > 0.05:
        print("  WARNING: T1 > 0.05 indicates significant multi-reference character.")

# ---------------------------------------------------------------------------
# Save results
# ---------------------------------------------------------------------------
results = {
    "uhf_energy": uhf_energy,
    "ccsd_corr": mycc.e_corr,
    "ccsd_total": mycc.e_tot,
    "ccsd_converged": mycc.converged,
    "method": "{{ label }}_hast_ucc",
    "cc_level": cc_level,
    "cas_n_elec": cas_n_elec,
    "cas_n_orb": cas_n_orb,
}
{% if cc_level >= 3 %}
if et_correction is not None:
    results["et_correction"] = et_correction
    results["ccsd_t_total"] = tailored_ccsd_t_energy
{% endif %}

np.savez("{{ label }}_hast_ucc_results.npz", **results)
print(f"\nResults saved to {{ label }}_hast_ucc_results.npz")
print("Done.")
